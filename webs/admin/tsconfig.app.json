{
  "extends": ["@vue/tsconfig/tsconfig.dom.json", "../../shared/tsconfig/common.json"],
  "include": ["env.d.ts", "./.types/*", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    // Extra safety for array and object lookups, but may have false positives.
    "noUncheckedIndexedAccess": true,

    "moduleResolution": "Bundler",

    "jsx": "preserve",
    "jsxImportSource": "vue-jsx-vapor",

    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking.
    // Specified here to keep it out of the root directory.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "types": ["@web/ui/types"],
    "paths": {
      "#eden": ["./eden/index.ts"],
      "#server/admin/*": ["../../servers/admin/src/*"],
      "#server/shared/*": ["../../servers/shared/src/*"],
      "#shared/*": ["../../shared/src/*"],
      "#ui/*": ["../ui/src/*"],
      "#web/admin/*": ["./src/*"],
      "#web/user/*": ["../user/src/*"],
      "elysia": ["../../servers/shared/node_modules/elysia"]
    }
  },
  "vueCompilerOptions": {
    "plugins": ["vue-router/volar/sfc-route-blocks", "vue-router/volar/sfc-typed-router"]
  }
}
