  "dependencies": {
    "@elysia/openapi": "^1.4.15",
    "@gr/shared": "workspace:*",
    "arkenv": "^0.11.0",
    "arktype": "^2.2.0",
    "drizzle-orm": "^0.45.2",
    "elysia": "latest",
    "jose": "^6.2.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/pg": "^8.20.0",
    "@typescript/native-preview": "^7.0.0-dev.20260427.1"
