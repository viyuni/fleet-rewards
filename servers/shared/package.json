      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "default": "./src/config.ts"
    },
    "./db": {
      "types": "./src/db/index.ts",
      "default": "./src/db/index.ts"
    },
    "./db/schema": {
      "types": "./src/db/schema/index.ts",
      "default": "./src/db/schema/index.ts"
    },
    "./errors": {
      "types": "./src/errors/index.ts",
      "default": "./src/errors/index.ts"
    },
    "./image": {
      "types": "./src/modules/image/index.ts",
      "default": "./src/modules/image/index.ts"
    },
    "./jwt": {
      "types": "./src/modules/jwt/index.ts",
      "default": "./src/modules/jwt/index.ts"
    },
    "./jwt/admin-auth": {
      "types": "./src/modules/jwt/admin-auth.ts",
      "default": "./src/modules/jwt/admin-auth.ts"
    },
    "./jwt/user-auth": {
      "types": "./src/modules/jwt/user-auth.ts",
      "default": "./src/modules/jwt/user-auth.ts"
    },
    "./setup-app": {
      "types": "./src/setup-app.ts",
