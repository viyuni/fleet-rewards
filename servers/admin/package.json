{
  "name": "@server/admin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/eden.d.mts"
  },
  "scripts": {
    "dev": "bun --no-orphans --cwd .. --env-file=./servers/admin/.env --watch ./servers/admin/src/app.ts",
    "test": "NODE_ENV=test bun --env-file=.env.test test --preload ./src/__tests__/setup-env.ts --pass-with-no-tests",
    "typecheck": "tsgo --build",
    "check": "vpr typecheck && vp lint && vp fmt",
    "generate:dts": "vp pack",
    "build": "bun build ./src/app.ts --compile --outfile gr"
  },
  "dependencies": {
    "@elysia/cors": "^1.4.2",
    "@elysia/html": "^1.4.1",
    "@elysia/static": "^1.4.10",
    "@internal/shared": "workspace:*",
    "@server/db": "workspace:*",
    "@server/shared": "workspace:*",
    "@t3-oss/env-core": "^0.13.10",
    "drizzle-orm": "^1.0.0-beta.22",
    "elysia": "^1.4.28",
    "sharp": "^0.34.5",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260427.1",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.10"
  }
