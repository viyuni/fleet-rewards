{
  "name": "@server/db",
  "version": "0.0.0",
  "description": "A starter for creating a TypeScript package.",
  "files": [
    "src"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./helper": "./src/helper/index.ts",
    "./migrate": "./src/migrate.ts",
    "./seed": "./src/seed.ts"
  },
  "scripts": {
    "test": "NODE_ENV=test bun --env-file=.env.test test --pass-with-no-tests",
    "typecheck": "tsgo --build",
    "check": "vpr typecheck && vp lint && vp fmt",
    "generate": "drizzle-kit generate",
    "push": "drizzle-kit push",
    "push:test": "bun --env-file=.env.test run push",
    "migrate": "drizzle-kit migrate",
    "migrate:test": "bun --env-file=.env.test run migrate",
    "studio": "drizzle-kit studio",
    "studio:test": "bun --env-file=.env.test run studio"
  },
  "dependencies": {
    "@server/shared": "workspace:*",
    "drizzle-orm": "^1.0.0-beta.22"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "drizzle-kit": "^1.0.0-beta.22",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.14"
  }
}
