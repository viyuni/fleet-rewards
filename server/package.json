{
  "name": "@server/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/eden.d.mts"
  },
  "scripts": {
    "dev:admin": "bun --env-file=.env --watch ./src/apps/admin/index.ts",
    "dev:user": "bun --env-file=.env --watch ./src/apps/user/index.ts",
    "build:admin": "bun build ./src/apps/admin/index.ts --compile --outfile dist/admin",
    "build:user": "bun build ./src/apps/user/index.ts --compile --outfile dist/user",
    "check": "vpr typecheck && vp lint && vp fmt",
    "generate:dts": "vp pack",
    "test": "bun --env-file=.env.test test --preload ./src/__tests__/setup-env.ts --pass-with-no-tests",
    "typecheck": "tsgo --build",
    "db:generate": "bun --env-file=.env drizzle-kit generate",
    "db:push": "bun --env-file=.env drizzle-kit push",
    "db:push:test": "bun --env-file=.env.test drizzle-kit push",
    "seed": "bun --env-file=.env ./src/db/seed.ts"
  },
  "dependencies": {
    "@elysia/cors": "^1.4.2",
    "@elysia/html": "^1.4.1",
    "@elysia/openapi": "^1.4.15",
    "@elysia/static": "^1.4.10",
    "@internal/shared": "workspace:*",
    "@t3-oss/env-core": "^0.13.11",
    "@valibot/to-json-schema": "^1.7.0",
    "drizzle-orm": "^1.0.0-beta.22",
    "elysia": "^1.4.28",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260427.1",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^1.0.0-beta.22"
  }
}
